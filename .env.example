# Copy to .env in the project root. Alpaca fetcher tries several key names (paper vs live).

# Common / fallback
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Paper trading (preferred for MAD live bot when MAD_LIVE_PAPER=True in config)
ALPACA_API_KEY_PAPER=
ALPACA_SECRET_KEY_PAPER=

# Live trading (when using live keys)
ALPACA_API_KEY_LIVE=
ALPACA_SECRET_KEY_LIVE=
